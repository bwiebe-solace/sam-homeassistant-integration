# ── Solace Broker ─────────────────────────────────────────────────────────────
# For development, use the Solace free cloud broker (solace.com/try-it-now)
SOLACE_BROKER_URL=wss://your-broker.messaging.solace.cloud:443
SOLACE_BROKER_USERNAME=solace-cloud-client
SOLACE_BROKER_PASSWORD=
SOLACE_BROKER_VPN=your-vpn-name

# Set to true to run without a broker (single-process dev mode)
SOLACE_DEV_MODE=false

# Queue behaviour — use true for local dev, false for production
USE_TEMPORARY_QUEUES=true

# ── Namespace ──────────────────────────────────────────────────────────────────
# Isolates all SAM topics/queues — change this if running multiple instances
NAMESPACE=sam

# ── LLM ───────────────────────────────────────────────────────────────────────
# Using Gemini via OpenAI-compatible endpoint (free tier available)
# Get your key at: https://aistudio.google.com/apikey
LLM_SERVICE_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_SERVICE_API_KEY=
LLM_MODEL_NAME=openai/gemini-2.0-flash

# ── HomeAssistant ──────────────────────────────────────────────────────────────
# Use your remote HA URL (Nabu Casa URL or your own port-forward)
HA_URL=https://your-ha-instance.ui.nabu.casa
# Long-Lived Access Token from HA Profile → Security
HA_TOKEN=

# ── Proxmox ───────────────────────────────────────────────────────────────────
PROXMOX_HOST=https://your-proxmox-host:8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=
PROXMOX_TOKEN_VALUE=

# ── PiHole ────────────────────────────────────────────────────────────────────
PIHOLE_HOST=http://your-pihole-host
PIHOLE_API_KEY=

# ── Artifact / Session storage ────────────────────────────────────────────────
# SQLite is fine for local dev; swap to postgres URL for production
SESSION_DATABASE_URL=sqlite:///session.db
ARTIFACT_BASE_PATH=/tmp/sam-homeassistant
