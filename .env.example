# ── Solace Broker ─────────────────────────────────────────────────────────────
# For development, use the Solace free cloud broker (solace.com/try-it-now)
SOLACE_BROKER_URL=wss://your-broker.messaging.solace.cloud:443
SOLACE_BROKER_USERNAME=solace-cloud-client
SOLACE_BROKER_PASSWORD=
SOLACE_BROKER_VPN=your-vpn-name

# ── Solace Broker MQTT (used by HA MQTT gateway) ───────────────────────────────
# Same broker as above — just the hostname, without scheme or port
SOLACE_MQTT_HOST=your-broker.messaging.solace.cloud
# 8883 = TLS (recommended), 1883 = plaintext
SOLACE_MQTT_PORT=8883
SOLACE_MQTT_TLS=true

# Set to true to run without a broker (single-process dev mode)
SOLACE_DEV_MODE=false

# Queue behaviour — use true for local dev, false for production
USE_TEMPORARY_QUEUES=true

# ── Namespace ──────────────────────────────────────────────────────────────────
# Isolates all SAM topics/queues — change this if running multiple instances
NAMESPACE=yourname-sam-ha

# ── LLM ───────────────────────────────────────────────────────────────────────
# Using Gemini via OpenAI-compatible endpoint (free tier available)
# Get your key at: https://aistudio.google.com/apikey
LLM_SERVICE_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_SERVICE_API_KEY=
LLM_MODEL_NAME=openai/gemini-2.5-flash

# ── HomeAssistant ──────────────────────────────────────────────────────────────
# Use your remote HA URL (Nabu Casa URL or your own port-forward)
HA_URL=https://your-ha-instance.ui.nabu.casa
# Long-Lived Access Token from HA Profile → Security
HA_TOKEN=

# ── HomeAssistant Agent Permissions ───────────────────────────────────────────
# Master kill switch — set true to disable all write and control tools
HA_READONLY=false
# Allow call_service to control devices (lights, switches, climate, media)
HA_ALLOW_DEVICE_CONTROL=true
# Allow call_service to trigger scripts and automations (requires DEVICE_CONTROL=true)
HA_ALLOW_SCRIPT_EXECUTION=true
# Allow creating and updating automations, scripts, and helpers
HA_ALLOW_CONFIG_WRITE=false
# Allow deleting automations and scripts — irreversible, disabled by default
HA_ALLOW_DELETES=false

# ── Research Agent (Web Search) ───────────────────────────────────────────────
# At least one search provider is required for the Research Agent.
# Google: get API key at console.cloud.google.com, CSE ID at cse.google.com
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=
# Tavily: get key at app.tavily.com (generous free tier, recommended)
TAVILY_API_KEY=

# ── Proxmox ───────────────────────────────────────────────────────────────────
PROXMOX_HOST=https://your-proxmox-host:8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=
PROXMOX_TOKEN_VALUE=

# ── PiHole ────────────────────────────────────────────────────────────────────
PIHOLE_HOST=http://your-pihole-host
PIHOLE_API_KEY=

# ── Web UI ─────────────────────────────────────────────────────────────────────
# Secret key for signing session cookies — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# ── Artifact / Session storage ────────────────────────────────────────────────
# SQLite is fine for local dev; swap to postgres URL for production
# When running in Docker these are overridden in docker-compose.yml to use /data
SESSION_DATABASE_URL=sqlite:///session.db
WEB_UI_GATEWAY_DATABASE_URL=sqlite:///webui_gateway.db
ORCHESTRATOR_DATABASE_URL=sqlite:///orchestrator.db
ARTIFACT_BASE_PATH=/tmp/sam-homeassistant

# ── Python binary (local development only) ─────────────────────────────────────
# Set this to your virtual environment Python path when running locally.
# Not needed in Docker (uses system Python).
# Example: PYTHON_BIN=/Users/yourname/Workspace/.venv/bin/python
# PYTHON_BIN=
